{% extends "layouts/page.njk" %}
{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block content %}
<div class="govuk-grid-row govuk-!-padding-top-6">
  <div class="govuk-grid-column-two-thirds">

    {{ govukPanel({
      titleText: title,
      html: "Your reference number<br><strong>" + reference + "</strong>" if (reference and showReference) else ""
    }) }}

    {% if confirmationEmailFailed %}
      {{ govukWarningText({
        text: "We could not send a confirmation email to your email address. Your submission was successful, but you will not receive an email confirmation.",
        iconFallbackText: "Warning"
      }) }}
    {% endif %}

    {{ content | safe }}

  </div>
</div>
{% endblock %}