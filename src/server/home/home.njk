{% extends "layouts/page.njk" %}

{% block pageTitle %}
  {{ pageTitle }} | {{ serviceName }}
{% endblock %}

{% block header %}
<header class="defra-header">
  <div class="defra-header__inner">
    <div class="defra-header__brand-group">
      <img
        src="{{ getAssetPath('images/defra-logo.svg') }}"
        alt=""
        role="presentation"
        class="defra-header__logo"
      />
      <a href="/" class="defra-header__service-name">
        <span class="govuk-visually-hidden">Department for Environment, Food and Rural Affairs: </span>{{ headerServiceName | default('Digital Defra') }}
      </a>
    </div>
    {% include "partials/header-search.njk" %}
  </div>
</header>
{% include "partials/main-navigation.njk" %}
{% endblock %}

{% block content %}
  <div class="defra-hero">
    <div class="defra-width-container">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h1 class="govuk-heading-xl">
            {{ heading }}
          </h1>
          <p class="govuk-body-l">
            Tools, guidance and support to help you design, build and operate successful services for Defra.
          </p>
        </div>
      </div>
    </div>
  </div>

  <div class="defra-width-container govuk-!-margin-top-5">
    <p class="govuk-body">To see some of this information you will need to sign in to Defra.</p>

    <ul class="defra-tile-grid defra-tile-grid--half">
      <li>
        <div class="defra-tile">
          <span class="govuk-caption-m">Guidance</span>
          <h2 class="govuk-heading-m defra-tile__title">
            <a href="/service-manual" class="defra-tile__link">Digital service manual</a>
          </h2>
          <p class="govuk-body defra-tile__body">Deliver services using Defra's standards and guidance.</p>
        </div>
      </li>

      <li>
        <div class="defra-tile">
          <span class="govuk-caption-m">Standard</span>
          <h2 class="govuk-heading-m defra-tile__title">
            <a href="/delivery-groups" class="defra-tile__link">Delivery groups</a>
          </h2>
          <p class="govuk-body defra-tile__body">Learn how delivery groups support your work.</p>
        </div>
      </li>
    </ul>

    <ul class="defra-tile-grid defra-tile-grid--half govuk-!-margin-top-2">
      <li>
        <div class="defra-tile">
          <span class="govuk-caption-m">Resources</span>
          <h2 class="govuk-heading-m defra-tile__title">
            <a href="/ai-playbook" class="defra-tile__link">AI digital toolkit</a>
          </h2>
          <p class="govuk-body defra-tile__body">Adopt AI responsibly with guidance, tools and patterns.</p>
        </div>
      </li>
    </ul>

  </div>
{% endblock %}
