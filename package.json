{
  "name": "service-manual-ui",
  "version": "0.0.0",
  "description": "CDP Frontend Template",
  "sideEffects": false,
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22.16.0"
  },
  "scripts": {
    "build:frontend": "cross-env NODE_ENV=production webpack",
    "dev": "cross-env NODE_ENV=development ENABLE_AI_CONTENT=true nodemon --exec \"node --env-file-if-exists .env\" src/index.js --watch src/server --watch src/client",
    "dev:debug": "run-p frontend:watch server:debug",
    "docker:dev": "npm run dev",
    "frontend:watch": "cross-env NODE_ENV=development webpack --watch",
    "git:pre-commit-hook": "npm run lint && npm test",
    "lint": "run-s lint:js lint:scss",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --cache --cache-location .cache/stylelint --cache-strategy content --color --ignore-path .gitignore",
    "test": "run-s build:frontend test:js",
    "test:js": "cross-env TZ=UTC vitest run --coverage",
    "test:watch": "cross-env TZ=UTC vitest",
    "server:watch": "nodemon --exec \"node --env-file-if-exists .env --inspect=0.0.0.0\" --ext js,json --legacy-watch ./src",
    "server:debug": "nodemon --exec \"node --env-file-if-exists .env --inspect-brk=0.0.0.0\" --ext js,json --legacy-watch ./src",
    "start": "run-s build:frontend start:server",
    "start:server": "NODE_ENV=production node --use-strict .",
    "setup:husky": "node --input-type=module -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\""
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@defra/cdp-auditing": "0.6.1",
    "@defra/hapi-secure-context": "0.4.0",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@hapi/catbox-memory": "6.0.2",
    "@hapi/catbox-redis": "7.0.2",
    "@hapi/hapi": "21.4.9",
    "@hapi/inert": "7.1.1",
    "@hapi/scooter": "8.0.0",
    "@hapi/vision": "7.0.3",
    "@hapi/yar": "11.0.3",
    "accessible-autocomplete": "3.0.1",
    "aws-embedded-metrics": "4.2.1",
    "blankie": "5.0.0",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "cssnano": "8.0.2",
    "cssnano-preset-default": "8.0.2",
    "date-fns": "4.4.0",
    "govuk-frontend": "6.2.0",
    "gray-matter": "4.0.3",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "3.0.1",
    "ioredis": "5.11.1",
    "joi": "18.2.3",
    "js-yaml": "4.2.0",
    "lodash": "4.18.1",
    "markdown-it": "14.2.0",
    "markdown-it-govuk": "0.9.0",
    "node-fetch": "3.3.2",
    "notifications-node-client": "8.4.0",
    "nunjucks": "3.2.4",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "semver": "7.8.4"
  },
  "devDependencies": {
    "@babel/preset-env": "7.29.7",
    "@vitest/coverage-v8": "4.1.9",
    "autoprefixer": "10.5.0",
    "babel-loader": "10.1.1",
    "cheerio": "1.2.0",
    "clean-webpack-plugin": "4.0.0",
    "concurrently": "10.0.3",
    "copy-webpack-plugin": "14.0.0",
    "cross-env": "10.1.0",
    "eslint": "9.39.2",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "neostandard": "0.13.0",
    "nock": "14.0.15",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.1",
    "sass-embedded": "1.100.0",
    "sass-loader": "17.0.0",
    "source-map-loader": "5.0.0",
    "stylelint": "17.13.0",
    "stylelint-config-gds": "3.0.0",
    "terser-webpack-plugin": "5.6.1",
    "vitest": "4.1.9",
    "vitest-fetch-mock": "0.4.5",
    "webpack": "5.107.2",
    "webpack-assets-manifest": "6.5.2",
    "webpack-cli": "7.0.3"
  },
  "overrides": {
    "fast-uri": "3.1.2",
    "joi": "18.2.3"
  }
}
